// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum LookingFor {
  FRIENDS
  DATING
  NETWORKING
  STUDY_BUDDY
}

enum InterestCategory {
  TECH
  ARTS
  SPORTS
  MUSIC
  GAMING
  TRAVEL
  FOOD
  ACADEMIA
  SOCIAL
  OTHER
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum MatchType {
  FRIEND
  DATE
  STUDY
}

enum RizzStatus {
  ACTIVE
  WAITING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum ConvoType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
  STICKER
  REACTION_BADGE
  SYSTEM
}

enum CommunityRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum ShipStatus {
  PENDING
  NOTIFIED
  CONNECTED
}

enum SubPlan {
  PREMIUM_MONTHLY
  PREMIUM_QUARTERLY
  PREMIUM_ANNUAL
}

enum SubStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED
}

enum NotifType {
  MATCH_REQUEST
  MATCH_ACCEPTED
  RIZZ_MESSAGE
  RIZZ_UNLOCKED
  RIZZ_EXPIRING
  COMMUNITY_INVITE
  SHIP_RECEIVED
  EVENT_REMINDER
  PROFILE_BOOST_EXPIRED
  NEW_MESSAGE
  SYSTEM
}

enum AllowFrom {
  EVERYONE
  MATCHES_ONLY
  NOBODY
}

enum ShowTo {
  EVERYONE
  CAMPUS_ONLY
  MATCHES_ONLY
  NOBODY
}

enum ReportTarget {
  USER
  POST
  COMMUNITY
  MESSAGE
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTION_TAKEN
  DISMISSED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phone           String?
  passwordHash    String
  firebaseUid     String?   @unique
  name            String
  username        String    @unique
  bio             String?   @db.VarChar(200)
  avatarUrl       String?
  dateOfBirth     String?
  gender          Gender?
  lookingFor      LookingFor[]
  collegeName     String?
  collegeEmail    String?   @unique
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  studentIdUrl    String?
  isActive        Boolean   @default(true)
  isOnline        Boolean   @default(false)
  lastSeen        DateTime  @default(now())
  isPremium       Boolean   @default(false)
  premiumExpiresAt DateTime?
  pushToken       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  interests       UserInterest[]
  sentMatches     Match[]   @relation("MatchSender")
  receivedMatches Match[]   @relation("MatchReceiver")
  conversations   ConversationParticipant[]
  communityMemberships CommunityMember[]
  posts           Post[]
  comments        Comment[]
  notifications   Notification[]
  ships           Ship[]    @relation("ShipInitiator")
  shipsReceived   Ship[]    @relation("ShipTargetOne")
  shipsReceivedTwo Ship[]   @relation("ShipTargetTwo")
  boosts          ProfileBoost[]
  blockedUsers    Block[]   @relation("BlockerRelation")
  blockedBy       Block[]   @relation("BlockedRelation")
  reports         Report[]  @relation("ReporterRelation")
  reportedBy      Report[]  @relation("TargetRelation")
  subscription    Subscription?
  privacy         UserPrivacy?
  rizzInitiated   RizzSession[] @relation("RizzInitiator")
  rizzReceived    RizzSession[] @relation("RizzTarget")
  messagesSent    Message[]
  rizzMessages    RizzMessage[]
  postLikes       PostLike[]
  consentLogs     ConsentLog[]
}

model Interest {
  id        String   @id @default(cuid())
  name      String   @unique
  emoji     String
  category  InterestCategory
  users     UserInterest[]
  communities Community[]
}

model UserInterest {
  userId     String
  interestId String
  weight     Float  @default(1.0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([userId, interestId])
}

model Match {
  id                 String      @id @default(cuid())
  senderId           String
  receiverId         String
  status             MatchStatus @default(PENDING)
  compatibilityScore Float?
  matchType          MatchType   @default(FRIEND)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  sender             User        @relation("MatchSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver           User        @relation("MatchReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model RizzSession {
  id               String     @id @default(cuid())
  initiatorId      String
  targetId         String
  initiatorMsgCount Int       @default(0)
  targetReplied    Boolean    @default(false)
  status           RizzStatus @default(ACTIVE)
  unlocked         Boolean    @default(false)
  expiresAt        DateTime
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  initiator        User       @relation("RizzInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  target           User       @relation("RizzTarget", fields: [targetId], references: [id], onDelete: Cascade)
  messages         RizzMessage[]

  @@unique([initiatorId, targetId])
  @@index([targetId, status])
  @@index([status, expiresAt])
}

model RizzMessage {
  id                 String      @id @default(cuid())
  sessionId          String
  senderId           String
  content            String      @db.VarChar(500)
  initiatorMsgNumber Int?
  isRead             Boolean     @default(false)
  readAt             DateTime?
  createdAt          DateTime    @default(now())
  session            RizzSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender             User        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Conversation {
  id           String    @id @default(cuid())
  type         ConvoType @default(DIRECT)
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ConversationParticipant {
  conversationId String
  userId         String
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  content        String?     @db.VarChar(2000)
  mediaUrl       String?
  messageType    MessageType @default(TEXT)
  isDeleted      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.VarChar(500)
  imageUrl    String?
  interestId  String?
  collegeName String?
  isPublic    Boolean  @default(true)
  memberCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  interest    Interest? @relation(fields: [interestId], references: [id])
  members     CommunityMember[]
  posts       Post[]
  events      Event[]

  @@index([collegeName])
}

model CommunityMember {
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([communityId, userId])
}

model Post {
  id           String    @id @default(cuid())
  authorId     String
  communityId  String?
  content      String    @db.VarChar(1000)
  mediaUrls    String[]
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community    Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  comments     Comment[]
  likes        PostLike[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String   @db.VarChar(500)
  createdAt DateTime @default(now())
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model PostLike {
  postId String
  userId String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model Event {
  id           String    @id @default(cuid())
  communityId  String
  title        String
  description  String?   @db.VarChar(1000)
  imageUrl     String?
  ticketPrice  Int?
  maxAttendees Int?
  attendeeCount Int      @default(0)
  venue        String?
  isOnline     Boolean   @default(false)
  scheduledAt  DateTime
  createdAt    DateTime  @default(now())
  community    Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
}

model Ship {
  id          String     @id @default(cuid())
  initiatorId String
  targetOneId String
  targetTwoId String
  message     String?    @db.VarChar(200)
  status      ShipStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  initiator   User @relation("ShipInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  targetOne   User @relation("ShipTargetOne", fields: [targetOneId], references: [id], onDelete: Cascade)
  targetTwo   User @relation("ShipTargetTwo", fields: [targetTwoId], references: [id], onDelete: Cascade)
}

model Subscription {
  id             String    @id @default(cuid())
  userId         String    @unique
  plan           SubPlan
  status         SubStatus @default(ACTIVE)
  razorpaySubId  String?
  startsAt       DateTime  @default(now())
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfileBoost {
  id             String   @id @default(cuid())
  userId         String
  expiresAt      DateTime
  razorpayOrderId String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String     @id @default(cuid())
  userId    String
  type      NotifType
  title     String
  body      String
  data      Json?
  isRead    Boolean    @default(false)
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model UserPrivacy {
  userId             String    @id
  showOnlineStatus   Boolean   @default(true)
  showLastSeen       Boolean   @default(true)
  allowMessagesFrom  AllowFrom @default(MATCHES_ONLY)
  showCollegeTo      ShowTo    @default(CAMPUS_ONLY)
  showAgeOnProfile   Boolean   @default(true)
  discoverableBy     ShowTo    @default(EVERYONE)
  allowShipsFrom     Boolean   @default(true)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User @relation("BlockerRelation", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User @relation("BlockedRelation", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetId   String
  targetType ReportTarget
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  reporter   User @relation("ReporterRelation", fields: [reporterId], references: [id], onDelete: Cascade)
  target     User @relation("TargetRelation", fields: [targetId], references: [id], onDelete: Cascade)
}

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  version     String
  ipAddress   String
  userAgent   String
  consentedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeletionAuditLog {
  id        String   @id @default(cuid())
  userId    String
  deletedAt DateTime @default(now())
  reason    String?
}
